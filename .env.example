# ── LLM (required: pick one backend) ─────────────────────────────────────────
LLM_BACKEND=anthropic                        # or: openrouter
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6            # current Sonnet; see https://docs.anthropic.com/en/docs/about-claude/models
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.6  # OpenRouter IDs use dots — see https://openrouter.ai/models
                                                 # cheap option: anthropic/claude-haiku-4.5  (~$1 per single_pass run)
                                                 # or:           openai/gpt-5.4-mini, deepseek/deepseek-v4-pro
ENABLE_PROMPT_CACHING=true

# ── Database (required) ───────────────────────────────────────────────────────
DB_PASSWORD=changeme
# Full postgres URL (overrides individual settings if set)
# POSTGRES_URL=postgresql://e2er:changeme@localhost:5432/e2er

# ── Data — Allium (optional) ──────────────────────────────────────────────────
# ALLIUM_API_KEY=...
AUTO_APPROVE_FEASIBILITY=true
MAX_QUERIES_PER_PAPER=20
MAX_ROWS_PER_PAPER=5000000

# ── Literature (all optional) ─────────────────────────────────────────────────
# LITERATURE_BIBTEX_FILE=/path/to/my_library.bib
# SEMANTIC_SCHOLAR_API_KEY=...   # free tier works without key

# ── GitHub (optional) ─────────────────────────────────────────────────────────
# GITHUB_TOKEN=ghp_...
# GITHUB_USERNAME=bhanneke
# GITHUB_ORG=                    # empty = personal account
GITHUB_PAPER_PREFIX=E2ER
GITHUB_PRIVATE_REPOS=true

# ── Pipeline ──────────────────────────────────────────────────────────────────
MAX_CONCURRENT_SPECIALISTS=3
SPECIALIST_TIMEOUT=3600
MAX_REVIEW_ROUNDS=3
WEAK_ACCEPT_THRESHOLD=7.0
DEFAULT_MAX_COST_USD=25.0   # fallback per-paper hard cap (overridable per paper)

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8300
LOG_LEVEL=INFO

# ── API security (only relevant for non-localhost deploys) ────────────────────
# When API_AUTH_TOKEN is set, mutating JSON endpoints (POST /api/papers,
# /cancel, /approve, /files) require `Authorization: Bearer <token>`.
# Leave unset for localhost dev. The HTML dashboard form (/papers) is NOT
# bearer-protected — browsers can't add Authorization headers to form POSTs;
# lock the dashboard down at the network layer (Tailscale/VPN/firewall) when
# you deploy beyond localhost. See SECURITY.md.
# API_AUTH_TOKEN=
#
# Comma-separated CORS allowed origins. Default permits the dashboard at
# localhost:8280. Add other origins as needed.
# CORS_ORIGINS=http://localhost:8280,http://127.0.0.1:8280
